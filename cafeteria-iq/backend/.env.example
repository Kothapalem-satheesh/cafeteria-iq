# Copy to .env and fill in. For MongoDB Atlas: Database > Connect > Drivers — copy the SRV string.
# Use database name cafeteria_iq (or change and run seed after).
PORT=5000
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER_HOST/cafeteria_iq?retryWrites=true&w=majority&appName=CafeIQ
JWT_SECRET=change_me_in_production
ML_SERVICE_URL=http://localhost:5001
NODE_ENV=development
